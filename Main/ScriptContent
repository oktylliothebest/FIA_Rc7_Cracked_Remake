			Change(Main_Frame, UDim2.new(Main_Frame.Position.X.Scale, Main_Frame.Position.X.Offset, 0.242, 0))
			ClickedTimes = 1
			task.delay(3, function()
				ClickedTimes = 1
			end)
		else
			ClickedTimes = ClickedTimes + 1
			task.delay(3, function()
				ClickedTimes = 1
			end)
		end
		task.delay(3, function()
			ClickedTimes = 1
		end)
	end)
	OpenBtn.MouseEnter:Connect(function()
		Hover("Button", "In", OpenBtn, Color3.fromRGB(50, 114, 255))
	end)
	OpenBtn.MouseLeave:Connect(function()
		Hover("Button", "Out", OpenBtn, Color3.fromRGB(85, 159, 255))
	end)
end
--|
SetupUI(CoreGui)
