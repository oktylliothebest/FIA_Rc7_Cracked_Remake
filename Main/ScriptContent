	local function Dragify(Object: Instance)
		local Dragging, DragInput, DragStart, StartPosition
		local TweeningData = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local function Update(Input)
			local Delta_UpperVariable = Input.Position - DragStart
			local NewPosition = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + Delta_UpperVariable.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta_UpperVariable.Y)
			TweenService:Create(Object, TweeningData, {Position = NewPosition}):Play()
		end
		Object.InputBegan:Connect(function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
				Dragging = true
				DragStart = Input.Position
				StartPosition = Object.Position
				Input.Changed:Connect(function()
					if Input.UserInputState == Enum.UserInputState.End then
						Dragging = false
					end
				end)
			end
		end)
		Object.InputChanged:Connect(function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputState.Change then
				DragInput = Input
			end
		end)
		UserInputService.InputChanged:Connect(function(Input)
			if Input == DragInput and Dragging then
				Update(Input)
			end
		end)
	end
	local function ChangeTheme(Indicator: any, Type: string)
		if Type == "Dark" or Type == "dark" or Type == "Black" or Type == "black" or Type == "Emo" or Type == "emo" then
			if typeof(Indicator) == "Instance" then
				--[[
			
					Instance Main
			
				--]]
				if Indicator:IsA("TextLabel") or Indicator:IsA("TextButton") then
					Indicator.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
					Indicator.TextColor3 = Color3.fromRGB(255, 255, 255)
				elseif Indicator:IsA("TextBox") then
					Indicator.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
					Indicator.PlaceholderColor3 = Color3.fromRGB(255, 255, 255)
					Indicator.TextColor3 = Color3.fromRGB(255, 255, 255)
				end
				--[[
			
					UI Designs
			
				--]]
				for _, obj in Indicator:GetDescendants() do
					if obj:IsA("UIGradient") then
						obj.Color = ColorSequence.new{
							ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
							ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
						}
					elseif obj:IsA("UIStroke") then
						obj.Color = Color3.fromRGB(0, 0, 0)
					end
				end
			elseif typeof(Indicator) == "string" then
				if Indicator == "System" or Indicator == "system" or Indicator == "Sys" or Indicator == "sys" or Indicator == "All" or Indicator == "all" then
					for _, obj in SimpleSevenX:GetDescendants() do
						if obj:IsA("TextLabel") or obj:IsA("TextButton") then
							obj.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
							obj.TextColor3 = Color3.fromRGB(255, 255, 255)
